# Required: Secret for JWT signing and token encryption
# Generate with: openssl rand -base64 32
MCP_SECRET=

# Required: Google OAuth credentials
# Create at: https://console.cloud.google.com/apis/credentials
# Redirect URI: https://your-domain.com/api/mcp/oauth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: Restrict login to a specific email domain (e.g., mycompany.com)
ALLOWED_DOMAIN=

# Optional: Apollo.io API key (only if using the Apollo server)
# Get from: https://app.apollo.io/#/settings/integrations/api
APOLLO_API_KEY=
