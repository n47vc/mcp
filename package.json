{
  "name": "@n47vc/mcp",
  "version": "0.4.2",
  "description": "Deploy MCP servers to Vercel in minutes. Includes Gmail, Google Drive, and Apollo.io servers with pluggable OAuth authentication.",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "tsc",
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "googleapis": "^144.0.0",
    "jose": "^5.10.0",
    "pdf-lib": "^1.17.1",
    "pdf2pic": "^3.1.4",
    "sharp": "^0.33.5"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "^1.25.0",
    "next": ">=14.0.0",
    "zod": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.25.2",
    "@types/node": "^20.0.0",
    "next": "^14.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0",
    "zod": "^3.23.0"
  }
}
